{
    "name": "@efffrida/rpc",
    "version": "0.0.31",
    "description": "effect rpc-frida",
    "keywords": [
        "effect-ts",
        "frida.re",
        "reverse engineering"
    ],
    "homepage": "https://github.com/leonitousconforti/efffrida",
    "license": "GPL-3.0-only",
    "author": "Leo Conforti <leo@leoconforti.us> (https://leoconforti.us)",
    "repository": {
        "type": "git",
        "url": "https://github.com/leonitousconforti/efffrida.git",
        "directory": "packages/rpc"
    },
    "files": [
        "src/**/*.ts",
        "dist/**/*.js",
        "dist/**/*.js.map",
        "dist/**/*.d.ts",
        "dist/**/*.d.ts.map"
    ],
    "type": "module",
    "sideEffects": [],
    "exports": {
        "./package.json": "./package.json",
        "./node": "./src/node/index.ts",
        "./frida": "./src/frida/index.ts",
        "./*": "./src/*.ts",
        "./internal/*": null,
        "./shared/*": null,
        "./*/index": null
    },
    "publishConfig": {
        "exports": {
            "./package.json": "./package.json",
            "./node": "./dist/node/index.js",
            "./frida": "./dist/frida/index.js",
            "./*": "./dist/*.js",
            "./internal/*": null,
            "./shared/*": null,
            "./*/index": null
        },
        "access": "public",
        "provenance": true
    },
    "scripts": {
        "codegen": "build-utils prepare-v4",
        "build": "tsc -b tsconfig.build.json && pnpm babel",
        "babel": "babel dist --plugins annotate-pure-calls --out-dir dist --source-maps",
        "check": "tsc -b tsconfig.json",
        "test": "vitest",
        "coverage": "vitest --coverage"
    },
    "dependencies": {
        "@efffrida/frida-tools": "workspace:*",
        "@efffrida/platform": "workspace:*",
        "@efffrida/polyfills": "workspace:*"
    },
    "devDependencies": {
        "@effect/platform-node": "4.0.0-beta.69",
        "@effect/vitest": "4.0.0-beta.69",
        "@types/frida-gum": "19.1.0",
        "@types/node": "25.9.0",
        "effect": "4.0.0-beta.69",
        "frida": "17.9.10",
        "ioredis": "5.10.1",
        "vitest": "4.1.6"
    },
    "peerDependencies": {
        "effect": "4.0.0-beta.69"
    },
    "tags": [
        "frida.re",
        "reverse engineering",
        "effect-ts"
    ]
}
