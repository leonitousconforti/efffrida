{
    "name": "@efffrida/gplayapi",
    "version": "0.0.8",
    "description": "Google play api",
    "keywords": [
        "effect-ts",
        "frida.re",
        "reverse engineering"
    ],
    "homepage": "https://github.com/leonitousconforti/efffrida",
    "license": "GPL-3.0-only",
    "author": "Leo Conforti <leo@leoconforti.us> (https://leoconforti.us)",
    "repository": {
        "type": "git",
        "url": "https://github.com/leonitousconforti/efffrida.git",
        "directory": "packages/gplayapi"
    },
    "files": [
        "src/**/*.ts",
        "dist/**/*.js",
        "dist/**/*.js.map",
        "dist/**/*.d.ts",
        "dist/**/*.d.ts.map",
        "protobuf/**/*.proto",
        "devices/**/*.properties"
    ],
    "type": "module",
    "sideEffects": [],
    "exports": {
        "./package.json": "./package.json",
        ".": "./src/index.ts",
        "./*": "./src/*.ts",
        "./internal/*": null,
        "./generated/*": null
    },
    "publishConfig": {
        "exports": {
            "./package.json": "./package.json",
            ".": "./dist/index.js",
            "./*": "./dist/*.js",
            "./internal/*": null,
            "./generated/*": null
        },
        "access": "public"
    },
    "scripts": {
        "codegen": "build-utils prepare-v4",
        "build": "tsc -b tsconfig.build.json && pnpm babel",
        "babel": "babel dist --plugins annotate-pure-calls --out-dir dist --source-maps",
        "check": "tsc -b tsconfig.json",
        "protobuf": "buf generate"
    },
    "dependencies": {
        "properties-file": "5.0.4"
    },
    "devDependencies": {
        "@bufbuild/buf": "1.69.0",
        "@bufbuild/protobuf": "2.12.0",
        "@effect/cluster": "0.58.2",
        "@effect/experimental": "0.60.0",
        "@effect/platform": "0.96.1",
        "@effect/platform-node": "0.106.0",
        "@effect/rpc": "0.75.1",
        "@effect/sql": "0.51.1",
        "@effect/workflow": "0.18.1",
        "@types/node": "25.7.0",
        "effect": "3.21.2"
    },
    "peerDependencies": {
        "@bufbuild/protobuf": "2.12.0",
        "@effect/platform": "0.96.1",
        "effect": "3.21.2"
    },
    "tags": [
        "frida.re",
        "reverse engineering",
        "effect-ts"
    ]
}
