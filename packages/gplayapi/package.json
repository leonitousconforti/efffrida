{
    "name": "@efffrida/gplayapi",
    "version": "0.0.13",
    "description": "Google play api",
    "keywords": [
        "effect-ts",
        "frida.re",
        "reverse engineering"
    ],
    "homepage": "https://github.com/leonitousconforti/efffrida",
    "license": "GPL-3.0-only",
    "author": "Leo Conforti <leo@leoconforti.us> (https://leoconforti.us)",
    "repository": {
        "type": "git",
        "url": "https://github.com/leonitousconforti/efffrida.git",
        "directory": "packages/gplayapi"
    },
    "files": [
        "src/**/*.ts",
        "dist/**/*.js",
        "dist/**/*.js.map",
        "dist/**/*.d.ts",
        "dist/**/*.d.ts.map",
        "protobuf/**/*.proto",
        "devices/**/*.properties"
    ],
    "type": "module",
    "sideEffects": [],
    "exports": {
        "./package.json": "./package.json",
        ".": "./src/index.ts",
        "./*": "./src/*.ts",
        "./internal/*": null,
        "./generated/*": null
    },
    "publishConfig": {
        "exports": {
            "./package.json": "./package.json",
            ".": "./dist/index.js",
            "./*": "./dist/*.js",
            "./internal/*": null,
            "./generated/*": null
        },
        "access": "public",
        "provenance": true
    },
    "scripts": {
        "codegen": "build-utils prepare-v4",
        "build": "tsc -b tsconfig.build.json && pnpm babel",
        "babel": "babel dist --plugins annotate-pure-calls --out-dir dist --source-maps",
        "check": "tsc -b tsconfig.json",
        "protobuf": "buf generate"
    },
    "devDependencies": {
        "@bufbuild/buf": "1.70.0",
        "@bufbuild/protobuf": "2.12.0",
        "@effect/platform-node": "4.0.0-beta.69",
        "@types/node": "25.9.1",
        "effect": "4.0.0-beta.69",
        "ioredis": "5.11.0"
    },
    "peerDependencies": {
        "@bufbuild/protobuf": "2.12.0",
        "effect": "4.0.0-beta.69"
    },
    "tags": [
        "frida.re",
        "reverse engineering",
        "effect-ts"
    ]
}
