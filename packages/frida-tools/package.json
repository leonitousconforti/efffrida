{
    "name": "@efffrida/frida-tools",
    "version": "0.0.36",
    "description": "Frida with effect-ts",
    "keywords": [
        "effect-ts",
        "frida.re",
        "reverse engineering"
    ],
    "homepage": "https://github.com/leonitousconforti/efffrida",
    "license": "GPL-3.0-only",
    "author": "Leo Conforti <leo@leoconforti.us> (https://leoconforti.us)",
    "repository": {
        "type": "git",
        "url": "https://github.com/leonitousconforti/efffrida.git",
        "directory": "packages/frida-tools"
    },
    "files": [
        "src/**/*.ts",
        "dist/**/*.js",
        "dist/**/*.js.map",
        "dist/**/*.d.ts",
        "dist/**/*.d.ts.map"
    ],
    "type": "module",
    "sideEffects": [],
    "exports": {
        "./package.json": "./package.json",
        ".": "./src/index.ts",
        "./*": "./src/*.ts",
        "./internal/*": null
    },
    "publishConfig": {
        "exports": {
            "./package.json": "./package.json",
            ".": "./dist/index.js",
            "./*": "./dist/*.js",
            "./internal/*": null
        },
        "access": "public",
        "provenance": true
    },
    "scripts": {
        "codegen": "build-utils prepare-v4",
        "build": "tsc -b tsconfig.build.json && pnpm babel",
        "babel": "babel dist --plugins annotate-pure-calls --out-dir dist --source-maps",
        "check": "tsc -b tsconfig.json",
        "test": "vitest",
        "coverage": "vitest --coverage"
    },
    "dependencies": {
        "frida": "17.12.0"
    },
    "devDependencies": {
        "@effect/platform-node": "4.0.0-beta.69",
        "@effect/vitest": "4.0.0-beta.69",
        "@types/frida-gum": "19.6.0",
        "@types/node": "25.9.1",
        "effect": "4.0.0-beta.69",
        "ioredis": "5.11.1",
        "vite": "8.0.16",
        "vitest": "4.1.8"
    },
    "peerDependencies": {
        "effect": "4.0.0-beta.69"
    },
    "tags": [
        "frida.re",
        "reverse engineering",
        "effect-ts"
    ]
}
