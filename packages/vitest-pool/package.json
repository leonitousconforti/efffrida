{
    "name": "@efffrida/vitest-pool",
    "version": "0.0.12",
    "description": "effect frida vitest-pool",
    "keywords": [
        "effect-ts",
        "frida.re",
        "reverse engineering"
    ],
    "homepage": "https://github.com/leonitousconforti/efffrida",
    "license": "GPL-3.0-only",
    "author": "Leo Conforti <leo@leoconforti.us> (https://leoconforti.us)",
    "repository": {
        "type": "git",
        "url": "https://github.com/leonitousconforti/efffrida.git",
        "directory": "packages/vitest-pool"
    },
    "files": [
        "src/**/*.ts",
        "dist/**/*.js",
        "dist/**/*.js.map",
        "dist/**/*.d.ts",
        "dist/**/*.d.ts.map"
    ],
    "type": "module",
    "sideEffects": [],
    "exports": {
        "./package.json": "./package.json",
        ".": "./src/index.ts",
        "./*": "./src/*.ts",
        "./internal/*": null
    },
    "publishConfig": {
        "exports": {
            "./package.json": "./package.json",
            ".": "./dist/src/index.js",
            "./*": "./dist/src/*.js",
            "./internal/*": null
        },
        "access": "public",
        "provenance": true
    },
    "scripts": {
        "codegen": "build-utils prepare-v4",
        "build": "tsc -b tsconfig.build.json && pnpm babel",
        "babel": "babel dist --plugins annotate-pure-calls --out-dir dist --source-maps",
        "check": "tsc -b tsconfig.json",
        "test": "vitest",
        "coverage": "vitest --coverage"
    },
    "dependencies": {
        "@efffrida/frida-tools": "workspace:*",
        "@efffrida/polyfills": "workspace:*",
        "@vitest/runner": "4.1.6",
        "@vitest/utils": "4.1.6",
        "birpc": "4.0.0",
        "esbuild": "0.28.0",
        "flatted": "3.4.2"
    },
    "devDependencies": {
        "@effect/cluster": "0.58.2",
        "@effect/experimental": "0.60.0",
        "@effect/platform": "0.96.1",
        "@effect/platform-node": "0.106.0",
        "@effect/rpc": "0.75.1",
        "@effect/sql": "0.51.1",
        "@effect/workflow": "0.18.1",
        "@types/frida-gum": "19.1.0",
        "@types/node": "25.7.0",
        "effect": "3.21.2",
        "frida": "17.9.8",
        "vitest": "4.1.6"
    },
    "peerDependencies": {
        "@effect/platform": "0.96.1",
        "@vitest/runner": "4.1.6",
        "@vitest/utils": "4.1.6",
        "effect": "3.21.2",
        "vitest": "4.1.6"
    },
    "tags": [
        "frida.re",
        "reverse engineering",
        "effect-ts"
    ]
}
