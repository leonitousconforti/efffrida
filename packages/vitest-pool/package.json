{
    "name": "@efffrida/vitest-pool",
    "version": "0.0.32",
    "description": "effect frida vitest-pool",
    "keywords": [
        "effect-ts",
        "frida.re",
        "reverse engineering"
    ],
    "homepage": "https://github.com/leonitousconforti/efffrida",
    "license": "GPL-3.0-only",
    "author": "Leo Conforti <leo@leoconforti.us> (https://leoconforti.us)",
    "repository": {
        "type": "git",
        "url": "https://github.com/leonitousconforti/efffrida.git",
        "directory": "packages/vitest-pool"
    },
    "files": [
        "src/**/*.ts",
        "dist/**/*.ts",
        "dist/**/*.js",
        "dist/**/*.js.map",
        "dist/**/*.d.ts",
        "dist/**/*.d.ts.map"
    ],
    "type": "module",
    "sideEffects": [],
    "exports": {
        "./package.json": "./package.json",
        ".": "./src/index.ts",
        "./*": "./src/*.ts",
        "./internal/*": null
    },
    "publishConfig": {
        "exports": {
            "./package.json": "./package.json",
            ".": "./dist/src/index.js",
            "./*": "./dist/src/*.js",
            "./internal/*": null
        },
        "access": "public",
        "provenance": true
    },
    "scripts": {
        "codegen": "build-utils prepare-v4",
        "build": "tsc -b tsconfig.build.json && pnpm copy-frida && pnpm babel",
        "copy-frida": "node -e \"const {cpSync}=require('fs');cpSync('frida','dist/frida',{recursive:true,force:true})\"",
        "babel": "babel dist --plugins annotate-pure-calls --out-dir dist --source-maps",
        "check": "tsc -b tsconfig.json",
        "test": "vitest",
        "coverage": "vitest --coverage"
    },
    "dependencies": {
        "@efffrida/frida-tools": "workspace:*",
        "frida": "17.15.5",
        "ioredis": "5.11.1"
    },
    "devDependencies": {
        "@effect/platform-node": "4.0.0-beta.99",
        "@efffrida/polyfills": "workspace:*",
        "@types/frida-gum": "19.10.0",
        "@types/node": "25.9.5",
        "@vitest/runner": "4.1.10",
        "@vitest/utils": "4.1.10",
        "birpc": "4.0.0",
        "effect": "4.0.0-beta.99",
        "flatted": "3.4.2",
        "vite": "8.1.5",
        "vitest": "4.1.10"
    },
    "peerDependencies": {
        "@effect/platform-node": "4.0.0-beta.99",
        "@efffrida/polyfills": "workspace:*",
        "@vitest/runner": "4.1.10",
        "@vitest/utils": "4.1.10",
        "birpc": "4.0.0",
        "effect": "4.0.0-beta.99",
        "flatted": "3.4.2",
        "vite": "8.1.5",
        "vitest": "4.1.10"
    },
    "tags": [
        "frida.re",
        "reverse engineering",
        "effect-ts"
    ]
}
