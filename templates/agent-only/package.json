{
    "name": "agent-only",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "exports": {
        "./package.json": "./package.json",
        ".": "./src/index.ts",
        "./*": "./src/*.ts"
    },
    "scripts": {
        "build": "tsc -b tsconfig.build.json",
        "check": "tsc -b tsconfig.json",
        "lint": "oxlint && oxfmt --check src",
        "lint-fix": "oxlint --fix && oxfmt --write src",
        "test": "vitest",
        "coverage": "vitest --coverage"
    },
    "dependencies": {
        "@efffrida/platform": "latest",
        "effect": "4.0.0-beta.69"
    },
    "devDependencies": {
        "@effect/language-service": "0.86.2",
        "@effect/platform-node": "4.0.0-beta.69",
        "@effect/vitest": "4.0.0-beta.69",
        "@efffrida/polyfills": "latest",
        "@efffrida/vitest-pool": "latest",
        "@types/frida-gum": "19.6.0",
        "@types/node": "25.9.1",
        "@vitest/coverage-v8": "4.1.8",
        "@vitest/runner": "4.1.8",
        "@vitest/utils": "4.1.8",
        "birpc": "4.0.0",
        "flatted": "3.4.2",
        "ioredis": "5.11.1",
        "oxfmt": "0.53.0",
        "oxlint": "1.68.0",
        "typescript": "6.0.3",
        "vite": "8.0.16",
        "vitest": "4.1.8"
    },
    "peerDependencies": {
        "effect": "4.0.0-beta.69"
    }
}
