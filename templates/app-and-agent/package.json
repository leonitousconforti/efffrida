        "@types/node": "25.9.5",
        "@vitest/coverage-v8": "4.1.10",
        "@vitest/runner": "4.1.10",
        "@vitest/utils": "4.1.10",
        "birpc": "4.0.0",
        "flatted": "3.4.2",
        "frida": "17.15.5",
        "ioredis": "5.11.1",
