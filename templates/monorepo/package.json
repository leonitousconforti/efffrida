{
    "private": true,
    "name": "<REPO_NAME>",
    "workspaces": ["packages/*"],
    "type": "module",
    "scripts": {
        "clean": "node scripts/clean.mjs",
        "build": "tsc -b tsconfig.build.json && pnpm --recursive --parallel --filter \"./packages/**/*\" run build",
        "circular": "node scripts/circular.mjs",
        "test": "vitest",
        "coverage": "vitest --coverage",
        "check": "tsc -b tsconfig.json",
        "lint": "oxlint --disable-nested-config && oxfmt --check packages scripts",
        "lint-fix": "oxlint --disable-nested-config --fix && oxfmt --write packages scripts",
        "changeset-version": "changeset version",
        "changeset-publish": "pnpm build && changeset publish"
    },
    "devDependencies": {
        "@changesets/cli": "2.31.0",
        "@changesets/config": "3.1.4",
        "@effect/language-service": "0.86.1",
        "@effect/vitest": "4.0.0-beta.69",
        "@efffrida/vitest-pool": "^0.0.15",
        "@types/frida-gum": "19.1.0",
        "@types/node": "25.9.0",
        "@vitest/coverage-v8": "4.1.6",
        "frida": "17.9.10",
        "glob": "13.0.6",
        "madge": "8.0.0",
        "oxfmt": "0.51.0",
        "oxlint": "1.66.0",
        "rimraf": "6.1.3",
        "typescript": "6.0.3",
        "vite": "8.0.14",
        "vitest": "4.1.6"
    },
    "packageManager": "pnpm@10.0.0"
}
